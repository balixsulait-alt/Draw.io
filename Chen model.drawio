        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;graph ER {\n    // Layout configurations to prevent crossing lines\n    overlap=false;\n    splines=true;\n    nodesep=0.8;\n    ranksep=1.2;\n\n    // 1. ENTITIES (Rectangles)\n    node [shape=box, style=filled, fillcolor=\&quot;#dae8fc\&quot;, color=\&quot;#6c8ebf\&quot;, fontname=\&quot;Helvetica-Bold\&quot;];\n    PERSON; PATIENT; STAFF; ROLE; WING; DRUG; CATEGORY; CATEGORY_TYPE; AILMENT; PROCEDURE; PRESCRIPTION; DISPENSE; MEDICAL_PROFILE; ALLERGY; CHRONIC_CONDITION; MEDICAL_HISTORY; GENEALOGY; USER_ACCOUNT; BILL; BILL_ITEM; PAYMENT;\n\n    // 2. RELATIONSHIPS (Diamonds)\n    node [shape=diamond, style=filled, fillcolor=\&quot;#fff2cc\&quot;, color=\&quot;#d6b656\&quot;, fontname=\&quot;Helvetica-Italic\&quot;];\n    becomes [label=\&quot;becomes\&quot;];\n    employed_as [label=\&quot;employed as\&quot;];\n    has_role [label=\&quot;has role\&quot;];\n    assigned_to_wing [label=\&quot;assigned to\&quot;];\n    admitted_to [label=\&quot;admitted to\&quot;];\n    defined_by [label=\&quot;defined by\&quot;];\n    classified_as [label=\&quot;classified as\&quot;];\n    treated_by [label=\&quot;treated by\&quot;];\n    written_by [label=\&quot;written by\&quot;];\n    prescribed_to [label=\&quot;prescribed to\&quot;];\n    includes_drug [label=\&quot;includes drug\&quot;];\n    includes_proc [label=\&quot;includes proc\&quot;];\n    dispensed_by [label=\&quot;dispensed by\&quot;];\n    dispensed_to [label=\&quot;dispensed to\&quot;];\n    contains_drug [label=\&quot;contains drug\&quot;];\n    owns_profile [label=\&quot;owns profile\&quot;];\n    has_allergy [label=\&quot;has allergy\&quot;];\n    has_condition [label=\&quot;has condition\&quot;];\n    history_of [label=\&quot;history of\&quot;];\n    recorded_by [label=\&quot;recorded by\&quot;];\n    diagnoses [label=\&quot;diagnoses\&quot;];\n    restricted_from [label=\&quot;restricted from\&quot;];\n    has_genealogy [label=\&quot;has genealogy\&quot;];\n    uses_account [label=\&quot;uses account\&quot;];\n    billed_to [label=\&quot;billed to\&quot;];\n    has_item [label=\&quot;has item\&quot;];\n    pays [label=\&quot;pays\&quot;];\n\n    // 3. ATTRIBUTES (Ovals)\n    node [shape=ellipse, style=filled, fillcolor=\&quot;#f5f5f5\&quot;, color=\&quot;#666666\&quot;, fontname=\&quot;Helvetica\&quot;];\n\n    // Person\n    person_id [label=&lt;&lt;U&gt;person_id&lt;/U&gt;&gt;];\n    first_name; last_name; dob; gender; contact; address;\n    PERSON -- {person_id first_name last_name dob gender contact address};\n\n    // Patient\n    patient_id [label=&lt;&lt;U&gt;patient_id&lt;/U&gt;&gt;];\n    patient_type; severity; status;\n    PATIENT -- {patient_id patient_type severity status};\n\n    // Staff &amp; Role\n    staff_id [label=&lt;&lt;U&gt;staff_id&lt;/U&gt;&gt;];\n    STAFF -- staff_id;\n    role_id [label=&lt;&lt;U&gt;role_id&lt;/U&gt;&gt;];\n    role_name;\n    ROLE -- {role_id role_name};\n\n    // Wing\n    wing_id [label=&lt;&lt;U&gt;wing_id&lt;/U&gt;&gt;];\n    wing_name; capacity;\n    WING -- {wing_id wing_name capacity};\n\n    // Drugs &amp; Categories\n    drug_id [label=&lt;&lt;U&gt;drug_id&lt;/U&gt;&gt;];\n    drug_name [label=\&quot;name\&quot;];\n    drug_cost [label=\&quot;cost\&quot;];\n    DRUG -- {drug_id drug_name drug_cost};\n\n    type_id [label=&lt;&lt;U&gt;type_id&lt;/U&gt;&gt;];\n    type_name;\n    CATEGORY_TYPE -- {type_id type_name};\n\n    category_id [label=&lt;&lt;U&gt;category_id&lt;/U&gt;&gt;];\n    category_name;\n    CATEGORY -- {category_id category_name};\n\n    // Medical\n    ailment_id [label=&lt;&lt;U&gt;ailment_id&lt;/U&gt;&gt;];\n    ailment_name [label=\&quot;name\&quot;];\n    AILMENT -- {ailment_id ailment_name};\n\n    procedure_id [label=&lt;&lt;U&gt;procedure_id&lt;/U&gt;&gt;];\n    proc_name [label=\&quot;name\&quot;];\n    proc_cost [label=\&quot;cost\&quot;];\n    PROCEDURE -- {procedure_id proc_name proc_cost};\n\n    prescription_id [label=&lt;&lt;U&gt;prescription_id&lt;/U&gt;&gt;];\n    presc_date [label=\&quot;date\&quot;];\n    PRESCRIPTION -- {prescription_id presc_date};\n\n    dispense_id [label=&lt;&lt;U&gt;dispense_id&lt;/U&gt;&gt;];\n    disp_date [label=\&quot;date\&quot;];\n    DISPENSE -- {dispense_id disp_date};\n\n    profile_id [label=&lt;&lt;U&gt;profile_id&lt;/U&gt;&gt;];\n    MEDICAL_PROFILE -- profile_id;\n\n    allergy_id [label=&lt;&lt;U&gt;allergy_id&lt;/U&gt;&gt;];\n    allergy_name [label=\&quot;name\&quot;];\n    ALLERGY -- {allergy_id allergy_name};\n\n    condition_id [label=&lt;&lt;U&gt;condition_id&lt;/U&gt;&gt;];\n    cond_name [label=\&quot;name\&quot;];\n    CHRONIC_CONDITION -- {condition_id cond_name};\n\n    history_id [label=&lt;&lt;U&gt;history_id&lt;/U&gt;&gt;];\n    hist_notes [label=\&quot;notes\&quot;];\n    hist_date [label=\&quot;date\&quot;];\n    MEDICAL_HISTORY -- {history_id hist_notes hist_date};\n\n    gene_id [label=&lt;&lt;U&gt;gene_id&lt;/U&gt;&gt;];\n    relation; details;\n    GENEALOGY -- {gene_id relation details};\n\n    // Admin &amp; Billing\n    account_id [label=&lt;&lt;U&gt;account_id&lt;/U&gt;&gt;];\n    username; password; is_admin;\n    USER_ACCOUNT -- {account_id username password is_admin};\n\n    bill_id [label=&lt;&lt;U&gt;bill_id&lt;/U&gt;&gt;];\n    total_amount; bill_status [label=\&quot;status\&quot;];\n    BILL -- {bill_id total_amount bill_status};\n\n    item_id [label=&lt;&lt;U&gt;item_id&lt;/U&gt;&gt;];\n    item_type; reference_id; item_cost [label=\&quot;cost\&quot;];\n    BILL_ITEM -- {item_id item_type reference_id item_cost};\n\n    payment_id [label=&lt;&lt;U&gt;payment_id&lt;/U&gt;&gt;];\n    amount; payment_date;\n    PAYMENT -- {payment_id amount payment_date};\n\n    // 4. RELATIONSHIP ATTRIBUTES (Ovals attached to Diamonds)\n    admission_date; discharge_date;\n    dosage;\n    quantity;\n    restrict_reason [label=\&quot;reason\&quot;];\n\n    admitted_to -- {admission_date discharge_date};\n    includes_drug -- dosage;\n    contains_drug -- quantity;\n    restricted_from -- restrict_reason;\n\n    // 5. EDGE CONNECTIONS (Connecting the diagram together)\n    PERSON -- becomes -- PATIENT;\n    PERSON -- employed_as -- STAFF;\n    STAFF -- has_role -- ROLE;\n    STAFF -- assigned_to_wing -- WING;\n    PATIENT -- admitted_to -- WING;\n    CATEGORY -- defined_by -- CATEGORY_TYPE;\n    DRUG -- classified_as -- CATEGORY;\n    DRUG -- treated_by -- AILMENT;\n\n    STAFF -- written_by -- PRESCRIPTION;\n    PATIENT -- prescribed_to -- PRESCRIPTION;\n    PRESCRIPTION -- includes_drug -- DRUG;\n    PRESCRIPTION -- includes_proc -- PROCEDURE;\n\n    STAFF -- dispensed_by -- DISPENSE;\n    PATIENT -- dispensed_to -- DISPENSE;\n    DISPENSE -- contains_drug -- DRUG;\n\n    PATIENT -- owns_profile -- MEDICAL_PROFILE;\n    PATIENT -- has_allergy -- ALLERGY;\n    PATIENT -- has_condition -- CHRONIC_CONDITION;\n\n    PATIENT -- history_of -- MEDICAL_HISTORY;\n    STAFF -- recorded_by -- MEDICAL_HISTORY;\n    AILMENT -- diagnoses -- MEDICAL_HISTORY;\n\n    PATIENT -- restricted_from -- DRUG;\n    PATIENT -- has_genealogy -- GENEALOGY;\n\n    STAFF -- uses_account -- USER_ACCOUNT;\n\n    PATIENT -- billed_to -- BILL;\n    BILL -- has_item -- BILL_ITEM;\n    BILL -- pays -- PAYMENT;\n}&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="pCF0OsTdfxcvkuniG3aF-1">
